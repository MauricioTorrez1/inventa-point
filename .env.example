# Copia este archivo a ".env" y rellena con los datos de tu proyecto Supabase.
# Settings -> API en el panel de Supabase.
# NOTA: la "anon key" es pública (segura para el navegador). NUNCA pongas aquí la service_role.

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica
